import { Button, ComboBox } from "std-widgets.slint";

component IconButton inherits Rectangle {
    in property <image> icon;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: touch-area.has-hover ? #e0e0e0 : transparent;

    Image {
        source: root.icon;
        width: 20px;
        height: 20px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component Launcher inherits Rectangle {
    width: 300px;
    height: 400px;
    background: #ffffff;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // ==========================================
        // 1. Top Section: Player Info (Weight: 8)
        // ==========================================
        Rectangle {
            vertical-stretch: 8;

            VerticalLayout {
                alignment: center;
                align-items: center;
                spacing: 8px;

                // Player Avatar (icon-player-avatar)
                Image {
                    width: 80px;
                    height: 80px;
                    source: @image-url("../assets/icon-player-avatar.svg");
                }

                // Login Method & Name (rec-launcher-player-info)
                HorizontalLayout {
                    height: 24px;
                    width: 140px;
                    spacing: 8px;

                    // Login Method Icon (icon-login-method)
                    Image {
                        width: 24px;
                        height: 24px;
                        source: @image-url("../assets/icon-login-method.svg");
                    }

                    // Player Name Label (label-player-name - fills remaining space)
                    Text {
                        color: #333333;
                        font-size: 12px;
                        vertical-alignment: center;
                        text: "Player";
                    }
                }
            }
        }

        // ==========================================
        // 2. Middle Section: Divider (Weight: 1)
        // ==========================================
        Rectangle {
            vertical-stretch: 1;
            min-height: 0px;
            background: transparent;
        }

        // ==========================================
        // 3. Bottom Section: Main Control Area (Weight: 9)
        // ==========================================
        VerticalLayout {
            vertical-stretch: 9;
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 0px;
            padding-bottom: 8px;
            spacing: 6px;
            alignment: end;

            // Notification/Tip Bar (rec-launcher-tip - responsive width)
            HorizontalLayout {
                height: 24px;
                spacing: 6px;

                // Tip Icon (icon-tip)
                Image {
                    width: 24px;
                    source: @image-url("../assets/icon-tip.svg");
                }

                // Tip Text (tet-tip - stretches elastically)
                Text {
                    color: #666666;
                    font-size: 11px;
                    vertical-alignment: center;
                    text: "Tip: Select an instance to get started";
                }
            }

            // Buttons Grid Layout (rec-launcher-btns - purely fluid grid)
            GridLayout {
                spacing: 4px;

                // --- Row 0 ---
                // Instance Management Button (btn-left-instance-manage)
                IconButton {
                    row: 0; col: 0;
                    icon: @image-url("../assets/icon-instance-manage.svg");
                }
                // Instance Selector (cbo-instance-choose - spans 2 columns)
                ComboBox {
                    row: 0; col: 1; colspan: 2;
                    model: ["Inst 1", "Inst 2", "Inst 3"];
                }
                // Download Button (btn-right-download)
                IconButton {
                    row: 0; col: 3;
                    icon: @image-url("../assets/icon-download.svg");
                }

                // --- Row 1 ---
                // Left Empty Button 1 (btn-left-empty1)
                Button {
                    row: 1; col: 0;
                    text: "•••";
                }
                // Core Launch Button (btn-launch - spans 2 columns & 2 rows)
                Button {
                    row: 1; col: 1; colspan: 2; rowspan: 2;
                    text: "Launch";
                    primary: true;
                }
                // Right Empty Button 1 (btn-right-empty1)
                Button {
                    row: 1; col: 3;
                    text: "•••";
                }

                // --- Row 2 ---
                // Left Empty Button 2 (btn-left-empty2)
                Button {
                    row: 2; col: 0;
                    text: "•••";
                }
                // Settings Button (btn-right-settings)
                IconButton {
                    row: 2; col: 3;
                    icon: @image-url("../assets/icon-settings.svg");
                }
            }
        }
    }
}
