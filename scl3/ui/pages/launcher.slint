import { Button, ComboBox } from "std-widgets.slint";
import { IconButton } from "../base/iconbutton.slint";

export component Launcher inherits Rectangle {
    width: 300px;
    height: 400px;

    in-out property <length> square-btn-size: 40px;
    in-out property <string> launch-button-text: "Launch";
    in-out property <string> player-name: "Player";
    in-out property <string> tip-text: "Tip: Select an instance to get started";
    in-out property <[string]> instance-model: ["Inst 1", "Inst 2", "Inst 3"];
    in-out property <image> avatar-image: @image-url("../../assets/icon-player-avatar.svg");
    in-out property <int> login-method-type: 0;
    in-out property <image> add-account-image: @image-url("../../assets/icon-add-account.svg");

    in-out property <int> current-account-index: 0;
    in-out property <int> account-count: 0;
    in-out property <int> selected-instance-index: -1;

    property <bool> is-add-account: root.current-account-index == root.account-count;

    callback launch-game();
    callback manage-instances();
    callback open-download();
    callback open-settings();
    callback instance-selected(value: string);
    callback account-switched(index: int);
    callback open-login();

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            vertical-stretch: 8;

            VerticalLayout {
                alignment: center;
                spacing: 8px;

                HorizontalLayout {
                    alignment: center;
                    TouchArea {
                        width: 100px;
                        height: 100px;
                        Image {
                            width: 100px;
                            height: 100px;
                            source: root.is-add-account ? root.add-account-image : root.avatar-image;
                        }
                        scroll-event(event) => {
                            if event.delta-y > 0px {
                                root.current-account-index = Math.mod(root.current-account-index - 1 + root.account-count + 1, root.account-count + 1);
                                root.account-switched(root.current-account-index);
                                accept
                            } else if event.delta-y < 0px {
                                root.current-account-index = Math.mod(root.current-account-index + 1, root.account-count + 1);
                                root.account-switched(root.current-account-index);
                                accept
                            } else {
                                reject
                            }
                        }
                    }
                }

                HorizontalLayout {
                    height: 24px;
                    alignment: center;
                    spacing: 8px;

                    if !root.is-add-account: Image {
                        width: 24px;
                        height: 24px;
                        source: root.login-method-type == 1 ? @image-url("../../assets/icon-login-microsoft.svg") : root.login-method-type == 2 ? @image-url("../../assets/icon-login-authlib.svg") : @image-url("../../assets/icon-login-offline.svg");
                    }

                    Text {
                        font-size: 1rem;
                        vertical-alignment: center;
                        text: root.is-add-account ? "添加账号" : root.player-name;
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            min-height: 0px;
            background: transparent;
        }

        VerticalLayout {
            vertical-stretch: 9;
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 0px;
            padding-bottom: 8px;
            spacing: 6px;
            alignment: end;

            HorizontalLayout {
                height: 24px;
                spacing: 6px;

                Image {
                    width: 24px;
                    source: @image-url("../../assets/icon-tip.svg");
                }

                Text {
                    font-size: 0.92rem;
                    vertical-alignment: center;
                    text: root.tip-text;
                }
            }

            GridLayout {
                spacing: 4px;

                IconButton {
                    row: 0; col: 0;
                    width: square-btn-size;
                    height: square-btn-size;
                    icon: @image-url("../../assets/icon-instance-manage.svg");
                    clicked => { root.manage-instances(); }
                }
                ComboBox {
                    row: 0; col: 1; colspan: 2;
                    height: square-btn-size;
                    model: root.instance-model;
                    current-index <=> root.selected-instance-index;
                    selected(value) => { root.instance-selected(value); }
                }
                IconButton {
                    row: 0; col: 3;
                    width: square-btn-size;
                    height: square-btn-size;
                    icon: @image-url("../../assets/icon-download.svg");
                    clicked => { root.open-download(); }
                }

                IconButton {
                    row: 1; col: 0;
                    width: square-btn-size;
                    height: square-btn-size;
                }
                Button {
                    row: 1; col: 1; colspan: 2; rowspan: 2;
                    text: root.is-add-account ? "登录" : root.launch-button-text;
                    primary: true;
                    clicked => {
                        if root.is-add-account {
                            root.open-login();
                        } else {
                            root.launch-game();
                        }
                    }
                }
                IconButton {
                    row: 1; col: 3;
                    width: square-btn-size;
                    height: square-btn-size;
                }

                IconButton {
                    row: 2; col: 0;
                    width: square-btn-size;
                    height: square-btn-size;
                }
                IconButton {
                    row: 2; col: 3;
                    width: square-btn-size;
                    height: square-btn-size;
                    icon: @image-url("../../assets/icon-settings.svg");
                    clicked => { root.open-settings(); }
                }
            }
        }
    }
}
