import { LineEdit, Palette, StyleMetrics } from "std-widgets.slint";

export component LoginOfflinePage inherits Rectangle {
    width: 360px;
    height: 480px;
    background: Palette.background;

    // 暴露给后端的属性，方便直接获取输入内容
    out property <string> username: username-input.text;
    out property <string> uuid: uuid-input.text;

    VerticalLayout {
        padding: 24px;
        spacing: 24px; // 控制大区块之间的间距
        alignment: start;

        // 1. 页面大标题
        Text {
            text: "创建离线账户";
            font-size: 20px;
            color: #222222;
        }

        // 2. 用户名输入区域
        VerticalLayout {
            spacing: 12px;
            
            Text {
                text: "用户名";
                font-size: 14px;
                color: #333333;
            }
            
            username-input := LineEdit {
                height: 38px;
                font-size: 14px;
                // 注意: 原图中的橙色边框为输入框获取焦点(Focus)时的状态。
                // 默认的 LineEdit 会根据系统/主题自动处理焦点样式。
            }
        }

        // 3. UUID 输入区域及提示文本
        VerticalLayout {
            spacing: 12px;
            
            Text {
                text: "用户统一标识（UUID）";
                font-size: 14px;
                color: #333333;
            }
            
            // 提示文本 (拆分为两个段落以还原图中的换行与间距)
            VerticalLayout {
                spacing: 14px;
                
                Text {
                    text: "如果你是通过其它启动器迁移到 SCL 的，你可能需要修改此处的标识来保证你存档物品的兼容";
                    font-size: 13px;
                    color: #111111;
                    wrap: word-wrap; // 允许长文本自动换行
                }
                
                Text {
                    text: "如果留空，则会根据用户名自动生成一个离线唯一标识\n(Bukkit 方式)";
                    font-size: 13px;
                    color: #111111;
                    wrap: word-wrap;
                }
            }

            uuid-input := LineEdit {
                height: 38px;
                font-size: 14px;
            }
        }

        // 4. 弹性占位符，将创建按钮推至底部，或者保持一定间距
        Rectangle { vertical-stretch: 1; }

        // 5. 底部橙色“创建”按钮
        Rectangle {
            height: 42px;
            background: #f05216;
            border-radius: 4px;
            
            Text {
                text: "创建";
                color: #ffffff;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            
            TouchArea {
                clicked => {
                    // 在此处触发向后端传递数据的回调
                    // 例如: root.create-account(root.username, root.uuid);
                }
            }
        }
    }
}