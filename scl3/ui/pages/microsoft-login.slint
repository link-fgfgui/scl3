import { Button, LineEdit, Palette, StyleMetrics, Spinner } from "std-widgets.slint";
import { PageContainer } from "../base/page-container.slint";

export component MicrosoftLogin inherits PageContainer {
    width: 300px;
    height: 400px;

    in-out property <string> verification-uri: "";
    in-out property <string> user-code: "";
    in-out property <string> message: "";
    in-out property <string> status-text: "正在获取认证码...";
    in-out property <bool> login-in-progress: false;
    in-out property <bool> can-complete-login: false;

    callback start-microsoft-login();
    callback complete-microsoft-login();

    init => {
        root.start-microsoft-login();
    }

    VerticalLayout {
        padding: StyleMetrics.layout-padding;
        spacing: StyleMetrics.layout-spacing;

        Text { text: "验证链接"; font-size: 0.92rem; color: Palette.foreground; }
        LineEdit {
            text: root.verification-uri;
            placeholder-text: "点击获取认证码后显示";
        }

        Text { text: "认证码"; font-size: 0.92rem; color: Palette.foreground; }
        LineEdit {
            text: root.user-code;
            placeholder-text: "复制到微软登录页面";
        }

        Text {
            text: root.message;
            font-size: 0.92rem;
            color: Palette.foreground;
            wrap: word-wrap;
        }

        if root.login-in-progress : HorizontalLayout {
            alignment: center;
            height: 32px;

            Spinner {
                indeterminate: true;
                width: 24px;
                height: 24px;
            }

            Text {
                text: root.status-text;
                font-size: 0.92rem;
                color: Palette.foreground;
                vertical-alignment: center;
            }
        }

        if !root.login-in-progress : Text {
            text: root.status-text;
            font-size: 0.92rem;
            color: Palette.foreground;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 8px;

            Button {
                text: "完成登录";
                primary: true;
                enabled: root.can-complete-login && !root.login-in-progress;
                clicked => { root.complete-microsoft-login(); }
            }
        }
    }
}
