import { Button, LineEdit, Palette, StyleMetrics } from "std-widgets.slint";
import { IconButton } from "../base/iconbutton.slint";

export component MicrosoftLogin inherits Rectangle {
    width: 300px;
    height: 400px;

    in-out property <string> client-id: "";
    in-out property <string> verification-uri: "";
    in-out property <string> user-code: "";
    in-out property <string> message: "";
    in-out property <string> status-text: "请输入 Azure AD Client ID，然后获取认证码";
    in-out property <bool> login-in-progress: false;
    in-out property <bool> can-complete-login: false;

    callback go-back();
    callback start-microsoft-login();
    callback complete-microsoft-login();
    callback config-changed();

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        HorizontalLayout {
            height: 36px;
            padding-left: 8px;
            padding-right: 8px;
            spacing: 8px;
            alignment: start;

            IconButton {
                width: 28px;
                height: 28px;
                icon-size: 28px;
                icon: @image-url("../../assets/icon-settings.svg");
                clicked => { root.go-back(); }
            }

            Text {
                font-size: 14px;
                font-weight: 700;
                vertical-alignment: center;
                text: "微软登录";
            }
        }

        VerticalLayout {
            padding: StyleMetrics.layout-padding;
            spacing: StyleMetrics.layout-spacing;

            Text { text: "Azure AD Client ID"; font-size: 11px; color: Palette.foreground; }
            LineEdit {
                text: root.client-id;
                placeholder-text: "设备码登录需要 Client ID";
                edited(val) => { root.client-id = val; root.config-changed(); }
            }

            Text { text: "验证链接"; font-size: 11px; color: Palette.foreground; }
            LineEdit {
                text: root.verification-uri;
                placeholder-text: "点击获取认证码后显示";
            }

            Text { text: "认证码"; font-size: 11px; color: Palette.foreground; }
            LineEdit {
                text: root.user-code;
                placeholder-text: "复制到微软登录页面";
            }

            Text {
                text: root.message;
                font-size: 11px;
                color: Palette.foreground;
                wrap: word-wrap;
            }

            Text {
                text: root.status-text;
                font-size: 11px;
                color: Palette.foreground;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;

                Button {
                    text: root.login-in-progress ? "正在获取..." : "获取认证码";
                    enabled: !root.login-in-progress;
                    clicked => { root.start-microsoft-login(); }
                }

                Button {
                    text: "完成登录";
                    primary: true;
                    enabled: root.can-complete-login && !root.login-in-progress;
                    clicked => { root.complete-microsoft-login(); }
                }
            }
        }
    }
}
